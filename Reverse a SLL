

 class Node {
     public int data;
     public Node next;

     Node()
     {
         this.data = 0;
         this.next = null;
     }
     Node(int data)
     {
         this.data = data;
         this.next = null;
     }
     Node(int data, Node next)
     {
         this.data = data;
         this.next = next;
     }
 }


public class Solution
{
    public static Node reverseLinkedList(Node head)
    {
        if (head == null || head.next == null) {
            return head;
        }

        Node reversedHead = reverseLinkedList(head.next);

        if (head.next != null) { 
            head.next.next = head; 
        }
        head.next = null; 

        return reversedHead;
        

    }
}
