

 class Node {
     public int data;
     public Node next;
     public Node prev;

     Node()
     {
         this.data = 0;
         this.next = null;
         this.prev = null;
     }

     Node(int data)
     {
         this.data = data;
         this.next = null;
         this.prev = null;
     }

     Node(int data, Node next)
     {
         this.data = data;
         this.next = next;
         this.prev = next;
     }
 };


public class Solution
{
    public static Node reverseDLL(Node head)
    {
        Node curr = head;
       Node back = null;
        if(head == null || head.next == null){
            return head;
        } 
        while(curr != null){
            back = curr.prev;
            curr.prev = curr.next;
            curr.next = back;
            curr = curr.prev;
        }
        return back.prev;
    }
}
