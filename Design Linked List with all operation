class MyLinkedList {
    // Inner class to define a Node
    private class Node {
        int data; // Stores the value of the node
        Node next; // Points to the next node in the list

        Node(int data) {
            this.data = data;
            this.next = null;
        }
    }

    private Node head; // Points to the first node of the linked list
    private int size;  // Stores the size of the linked list

    /** Initialize the linked list */
    public MyLinkedList() {
        head = null; // Initially, the list is empty
        size = 0;    // Size is set to 0
    }

    /** Get the value of the index-th node in the linked list. If the index is invalid, return -1. */
    public int get(int index) {
        if (index < 0 || index >= size) return -1; // Check if the index is out of bounds
        
        Node temp = head; // Start from the head
        for (int i = 0; i < index; i++) { // Move `temp` to the `index`-th node
            temp = temp.next;
        }
        return temp.data; // Return the value of the found node
    }

    /** Add a node at the beginning (head) of the linked list */
    public void addAtHead(int val) {
        Node newNode = new Node(val); // Create a new node
        newNode.next = head; // New node points to the current head
        head = newNode; // Update head to the new node
        size++; // Increase the size
    }

    /** Append a node at the end (tail) of the linked list */
    public void addAtTail(int val) {
        Node newNode = new Node(val); // Create a new node
        
        if (head == null) { // If the list is empty, set head to the new node
            head = newNode;
        } else {
            Node temp = head;
            while (temp.next != null) { // Traverse to the last node
                temp = temp.next;
            }
            temp.next = newNode; // Link last node to the new node
        }
        size++; // Increase the size
    }

    /** Add a node at the given index */
    public void addAtIndex(int index, int val) {
        if (index < 0 || index > size) return; // Check if index is out of bounds

        if (index == 0) { // If index is 0, insert at the head
            addAtHead(val);
            return;
        }

        if (index == size) { // If index is equal to size, insert at the tail
            addAtTail(val);
            return;
        }

        Node newNode = new Node(val); // Create a new node
        Node temp = head;
        
        // Traverse to the (index-1)th node
        for (int i = 0; i < index - 1; i++) {
            temp = temp.next;
        }

        newNode.next = temp.next; // New node points to the current `index` node
        temp.next = newNode; // (index-1) node points to the new node
        size++; // Increase the size
    }

    /** Delete the node at the given index */
    public void deleteAtIndex(int index) {
        if (index < 0 || index >= size) return; // Check if index is out of bounds

        if (index == 0) { // If deleting the head
            head = head.next; // Move head to the next node
        } else {
            Node temp = head;
            for (int i = 0; i < index - 1; i++) { // Traverse to (index-1)th node
                temp = temp.next;
            }
            temp.next = temp.next.next; // Skip the `index`-th node
        }
        size--; // Decrease the size
    }
}

